# Generate MASTER_SEED with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This is your root secret. Back it up. Losing it means losing all notes.
MASTER_SEED=

# Fine-grained GitHub PAT — scope: Contents (Read & Write) on this repo only.
# Create at: https://github.com/settings/personal-access-tokens/new
GITHUB_PAT=

# Target repository in "owner/repo" format
GITHUB_REPO=
